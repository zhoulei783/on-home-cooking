<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 对应 UserMapper 接口 -->
<mapper namespace="com.cooking.mapper.UserMapper">
    <!-- 基础字段映射（通用查询/插入/更新） -->
    <sql id="Base_Column_List">
        id, username, password, phone, address, balance, create_time
    </sql>

    <!-- 根据ID查询用户 -->
    <select id="selectById" parameterType="java.lang.Long" resultType="com.cooking.entity.User">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>

    <!-- 根据手机号查询用户（核心业务查询） -->
    <select id="selectByPhone" parameterType="java.lang.String" resultType="com.cooking.entity.User">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE phone = #{phone}
    </select>

    <!-- 新增用户 -->
    <insert id="insert" parameterType="com.cooking.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (
            username, password, phone, address, balance, create_time
        ) VALUES (
                     #{username}, #{password}, #{phone}, #{address}, #{balance}, NOW()
                 )
    </insert>

    <!-- 单独更新密码 -->
    <update id="updatePasswordById" parameterType="map">
        UPDATE user
        SET password = #{password}
        WHERE id = #{userId}
    </update>

    <!-- 更新余额（充值） -->
    <update id="updateBalance" parameterType="map">
        UPDATE user
        SET balance = balance + #{amount}
        WHERE id = #{userId}
    </update>

    <!-- 分页查询用户（支持模糊查询用户名） -->
    <select id="selectUserPage" parameterType="map" resultType="com.cooking.entity.User">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        <where>
            <if test="map.username != null and map.username != ''">
                AND username LIKE CONCAT('%', #{map.username}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
</mapper>